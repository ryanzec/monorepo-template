{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    // be explicit about types included
    // to avoid clashing with Jest types
    "types": ["cypress", "cypress-real-events", "cypress-visual-regression"]
  },
  "include": [
    "../node_modules/cypress",
    "./**/*.ts",
    "./**/*.tsx"
  ]
}
