{
  "name": "monorepo-template",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build:web": "tsc && vite --config ./applications/web/vite.config.ts build",
    "build:web:check": "tsc",
    "cypress:open-components": "./node_modules/.bin/cypress open-ct",
    "lint": "./node_modules/.bin/eslint --cache --ext .jsx --ext .js --ext ts --ext tsx ./",
    "lint:production": "./node_modules/.bin/eslint --no-eslintrc --config .eslintrc.production.json --cache --ext .jsx --ext .js --ext ts --ext tsx ./",
    "lint:fix": "./node_modules/.bin/eslint --cache --fix --ext .jsx --ext .js --ext ts --ext tsx ./packages",
    "preview:web": "vite --config ./applications/web/vite.config.ts preview",
    "start:api": "nodemon --watch application/api --ignore applications/api/lowdb/* --exec 'node --experimental-specifier-resolution=node --loader ts-node/esm' applications/api/src/server.ts",
    "start:web": "vite --config ./applications/web/vite.config.ts --port 4000",
    "test:unit": "rm -rf .nyc_output && ./node_modules/.bin/cypress run-ct -C ./cypress.json",
    "test:visual": "./node_modules/.bin/cypress run-ct -C ./cypress.visual.json --env type=actual",
    "test:visual:update": "./node_modules/.bin/cypress run-ct -C ./cypress.visual.json --env type=base",
    "test:unit:videos": "./node_modules/.bin/cypress run-ct -C ./cypress.videos.json",
    "storybook": "start-storybook -p 6006"
  },
  "dependencies": {
    "@cypress/vite-dev-server": "2.2.3",
    "@emotion/css": "11.9.0",
    "@emotion/react": "11.9.0",
    "@emotion/styled": "11.8.1",
    "@fontsource/inter": "4.5.10",
    "@fortawesome/fontawesome-svg-core": "6.1.1",
    "@fortawesome/free-solid-svg-icons": "6.1.1",
    "@fortawesome/react-fontawesome": "0.1.18",
    "@hookform/resolvers": "2.8.10",
    "axios": "0.27.2",
    "downshift": "6.1.7",
    "immer": "9.0.14",
    "lodash": "4.17.21",
    "react": "18.1.0",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-dom": "18.1.0",
    "react-hook-form": "7.31.2",
    "react-router-dom": "6.3.0",
    "react-virtuoso": "2.12.0",
    "uuid": "8.3.2",
    "zod": "3.17.3"
  },
  "devDependencies": {
    "@cypress/code-coverage": "3.9.12",
    "@cypress/react": "5.12.5",
    "@emotion/babel-plugin": "11.9.2",
    "@faker-js/faker": "7.1.0",
    "@loadable/component": "5.15.2",
    "@storybook/addon-actions": "6.5.5",
    "@storybook/addon-essentials": "6.5.5",
    "@storybook/addon-links": "6.5.5",
    "@storybook/react": "6.5.5",
    "@storybook/testing-react": "1.3.0",
    "@testing-library/react": "13.2.0",
    "@types/axios": "0.14.0",
    "@types/cors": "2.8.12",
    "@types/express": "4.17.13",
    "@types/loadable__component": "5.13.4",
    "@types/lodash": "4.14.182",
    "@types/node": "14.18.18",
    "@types/react": "18.0.9",
    "@types/react-dnd": "3.0.2",
    "@types/react-dnd-html5-backend": "3.0.2",
    "@types/react-dom": "18.0.5",
    "@types/react-fontawesome": "1.6.5",
    "@types/sinon": "10.0.11",
    "@types/uuid": "8.3.4",
    "@typescript-eslint/eslint-plugin": "5.26.0",
    "@typescript-eslint/parser": "5.26.0",
    "@vitejs/plugin-react": "1.3.2",
    "cors": "2.8.5",
    "cypress": "9.7.0",
    "cypress-real-events": "1.7.0",
    "cypress-visual-regression": "1.7.0",
    "dotenv": "16.0.1",
    "eslint": "8.16.0",
    "eslint-config-prettier": "8.5.0",
    "eslint-plugin-prettier": "4.0.0",
    "eslint-plugin-react": "7.30.0",
    "eslint-plugin-react-hooks": "4.5.0",
    "express": "4.18.1",
    "husky": "7.0.4",
    "lint-staged": "12.4.2",
    "lowdb": "3.0.0",
    "mini-css-extract-plugin": "2.6.0",
    "nodemon": "2.0.16",
    "prettier": "2.6.2",
    "sinon": "14.0.0",
    "ts-node": "10.8.0",
    "typescript": "4.7.2",
    "vite": "2.9.9",
    "vite-plugin-istanbul": "2.7.3"
  },
  "packageManager": "yarn@3.2.1"
}
